  "decisions": [
    {
      "id": "D1",
      "title": "hud-name-contract",
      "decision": "사용자 대화에서 HUD는 현재 Discord/OpenClaw session의 pinned OpenClaw status message를 뜻한다."
    },
    {
      "id": "D2",
      "title": "event-based-refresh",
      "decision": "HUD 갱신은 작업 이벤트 기반으로 한다. high-frequency polling은 도입하지 않는다."
    },
    {
      "id": "D3",
      "title": "canonical-state-root-only",
      "decision": "runtime state는 `openclaw-orchestrator/state/task-hud/`를 canonical root로 사용한다."
    },
    {
      "id": "D4",
      "title": "thirty-minute-stale-threshold",
      "decision": "active work 중 마지막 HUD update가 30분을 넘으면 stale로 본다."
    }
  ],
