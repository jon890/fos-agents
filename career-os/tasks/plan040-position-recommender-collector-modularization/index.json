  "decisions": [
    {
      "id": "D1",
      "title": "no-new-sources",
      "decision": "이번 plan은 새 채용 source를 추가하지 않고 현재 Wanted/Toss 수집 동작을 보존한다."
    },
    {
      "id": "D2",
      "title": "collector-produces-clean-candidates",
      "decision": "collector는 active/open direct posting 후보와 누수 차단만 책임지고, ranking/fit/gap/career narrative는 LLM 책임으로 둔다."
    },
    {
      "id": "D3",
      "title": "entrypoint-compatible",
      "decision": "기존 CLI entrypoint scripts/position-recommender/collect_live_postings.ts는 유지해 run_daily_with_claude.sh의 광범위 변경을 피한다."
    },
    {
      "id": "D4",
      "title": "docs-readonly-during-phases",
      "decision": "phase 실행 중 docs drift가 발견되면 docs를 patch하지 않고 PHASE_BLOCKED로 중단한다."
    }
  ],
